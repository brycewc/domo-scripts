DOMO_INSTANCE=your-instance
DOMO_ACCESS_TOKEN=your-access-token

# To target multiple Domo instances, copy this file to .env.<name> (e.g.
# .env.prod, .env.sandbox) and select it at runtime with --env <name>:
#
#   node cli.js --env prod bulk-rename-datasets --file ds.csv
#
# A bare .env (if present) is loaded as a fallback for shared defaults.
